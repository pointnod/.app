# ============================================
# .gitignore — pointnod-app v1.1.0
# Séparation stricte : code source ↔ artefacts
# ============================================

# ── Dépendances Node ──
node_modules/
**/node_modules/

# ── Build Vite (régénérable via `npm run build`) ──
dist/
**/dist/

# ── Outils de compilation portables (JDK, SDK, DevEnv) ──
.dev-env/
.tools/
.backups/

# ── Artefacts de build Android (Gradle) ──
platforms/android-apk/.gradle/
platforms/android-apk/app/build/
platforms/android-apk/build/
*.apk
*.aab

# ── Fichiers système ──
.DS_Store
Thumbs.db
*.log
